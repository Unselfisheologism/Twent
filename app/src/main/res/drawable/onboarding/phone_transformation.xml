<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    
    <aapt:attr name="android:drawable">
        <vector
            android:width="200dp"
            android:height="200dp"
            android:viewportWidth="200"
            android:viewportHeight="200">
            
            <!-- Phone outline -->
            <group
                android:name="phone_group"
                android:pivotX="100"
                android:pivotY="100">
                <path
                    android:name="phone_body"
                    android:pathData="M60,30 L140,30 Q150,30 150,40 L150,160 Q150,170 140,170 L60,170 Q50,170 50,160 L50,40 Q50,30 60,30 Z"
                    android:fillColor="#00000000"
                    android:strokeColor="#FF80C0F0"
                    android:strokeWidth="3" />
                
                <!-- Screen -->
                <path
                    android:name="phone_screen"
                    android:pathData="M65,45 L135,45 L135,155 L65,155 Z"
                    android:fillColor="#FF141414"
                    android:strokeColor="#FF282828"
                    android:strokeWidth="1" />
                
                <!-- Home button -->
                <path
                    android:name="home_button"
                    android:pathData="M100,160 A5,5 0,1 1 100,170 A5,5 0,1 1 100,160 Z"
                    android:fillColor="#FF282828" />
            </group>
            
            <!-- Feature connections -->
            <group
                android:name="connections_group"
                android:pivotX="100"
                android:pivotY="100">
                
                <!-- AI Agent node -->
                <path
                    android:name="ai_agent"
                    android:pathData="M30,50 A10,10 0,1 1 30,70 A10,10 0,1 1 30,50 Z"
                    android:fillColor="#FFF09020"
                    android:strokeColor="#FFD07010"
                    android:strokeWidth="2" />
                
                <!-- Terminal node -->
                <path
                    android:name="terminal"
                    android:pathData="M170,50 A10,10 0,1 1 170,70 A10,10 0,1 1 170,50 Z"
                    android:fillColor="#FF80C0F0"
                    android:strokeColor="#FF60A0D0"
                    android:strokeWidth="2" />
                
                <!-- Apps node -->
                <path
                    android:name="apps"
                    android:pathData="M30,130 A10,10 0,1 1 30,150 A10,10 0,1 1 30,130 Z"
                    android:fillColor="#FF405050"
                    android:strokeColor="#FF506060"
                    android:strokeWidth="2" />
                
                <!-- Workflows node -->
                <path
                    android:name="workflows"
                    android:pathData="M170,130 A10,10 0,1 1 170,150 A10,10 0,1 1 170,130 Z"
                    android:fillColor="#FF90A0A0"
                    android:strokeColor="#FF708080"
                    android:strokeWidth="2" />
                
                <!-- Connection lines -->
                <path
                    android:name="line1"
                    android:pathData="M40,60 L60,60"
                    android:strokeColor="#FFF09020"
                    android:strokeWidth="2"
                    android:strokeAlpha="0" />
                <path
                    android:name="line2"
                    android:pathData="M160,60 L140,60"
                    android:strokeColor="#FF80C0F0"
                    android:strokeWidth="2"
                    android:strokeAlpha="0" />
                <path
                    android:name="line3"
                    android:pathData="M40,140 L60,140"
                    android:strokeColor="#FF405050"
                    android:strokeWidth="2"
                    android:strokeAlpha="0" />
                <path
                    android:name="line4"
                    android:pathData="M160,140 L140,140"
                    android:strokeColor="#FF90A0A0"
                    android:strokeWidth="2"
                    android:strokeAlpha="0" />
            </group>
        </vector>
    </aapt:attr>
    
    <!-- Phone glow animation -->
    <target android:name="phone_body">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeColor"
                    android:valueFrom="#FF80C0F0"
                    android:valueTo="#FFFFFFFF"
                    android:duration="1000"
                    android:startOffset="1000"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Feature nodes appearing animation -->
    <target android:name="ai_agent">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="1500"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="1500"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="terminal">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="1800"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="1800"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="apps">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2100"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2100"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="workflows">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2400"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2400"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Connection lines appearing -->
    <target android:name="line1">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="300"
                    android:startOffset="1700"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="line2">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="300"
                    android:startOffset="2000"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="line3">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="300"
                    android:startOffset="2300"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="line4">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="300"
                    android:startOffset="2600"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>