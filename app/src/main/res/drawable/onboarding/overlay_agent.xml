<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    
    <aapt:attr name="android:drawable">
        <vector
            android:width="200dp"
            android:height="200dp"
            android:viewportWidth="200"
            android:viewportHeight="200">
            
            <!-- Phone outline -->
            <group
                android:name="phone_group"
                android:pivotX="100"
                android:pivotY="100">
                <path
                    android:name="phone_body"
                    android:pathData="M60,30 L140,30 Q150,30 150,40 L150,160 Q150,170 140,170 L60,170 Q50,170 50,160 L50,40 Q50,30 60,30 Z"
                    android:fillColor="#00000000"
                    android:strokeColor="#FF80C0F0"
                    android:strokeWidth="3" />
                
                <!-- Screen -->
                <path
                    android:name="phone_screen"
                    android:pathData="M65,45 L135,45 L135,155 L65,155 Z"
                    android:fillColor="#FF141414"
                    android:strokeColor="#FF282828"
                    android:strokeWidth="1" />
                
                <!-- App icons on screen -->
                <group android:name="app_icons">
                    <path
                        android:name="app1"
                        android:pathData="M75,55 A8,8 0,1 1 75,71 A8,8 0,1 1 75,55 Z"
                        android:fillColor="#FF4CAF50" />
                    <path
                        android:name="app2"
                        android:pathData="M95,55 A8,8 0,1 1 95,71 A8,8 0,1 1 95,55 Z"
                        android:fillColor="#FF2196F3" />
                    <path
                        android:name="app3"
                        android:pathData="M115,55 A8,8 0,1 1 115,71 A8,8 0,1 1 115,55 Z"
                        android:fillColor="#FFFF9800" />
                    <path
                        android:name="app4"
                        android:pathData="M75,80 A8,8 0,1 1 75,96 A8,8 0,1 1 75,80 Z"
                        android:fillColor="#FF9C27B0" />
                    <path
                        android:name="app5"
                        android:pathData="M95,80 A8,8 0,1 1 95,96 A8,8 0,1 1 95,80 Z"
                        android:fillColor="#FF00BCD4" />
                    <path
                        android:name="app6"
                        android:pathData="M115,80 A8,8 0,1 1 115,96 A8,8 0,1 1 115,80 Z"
                        android:fillColor="#FF607D8B" />
                </group>
            </group>
            
            <!-- Overlay agent circle -->
            <group
                android:name="overlay_group"
                android:pivotX="100"
                android:pivotY="100">
                <path
                    android:name="overlay_circle"
                    android:pathData="M100,100 A0,0 0,1 1 100,100 A0,0 0,1 1 100,100 Z"
                    android:fillColor="#00000000"
                    android:strokeColor="#FFF09020"
                    android:strokeWidth="3"
                    android:strokeAlpha="0" />
                
                <!-- Agent eye in overlay -->
                <path
                    android:name="agent_eye"
                    android:pathData="M100,100 A0,0 0,1 1 100,100 A0,0 0,1 1 100,100 Z"
                    android:fillColor="#FFF09020"
                    android:fillAlpha="0" />
                
                <!-- Divine glow -->
                <path
                    android:name="divine_glow"
                    android:pathData="M100,100 A0,0 0,1 1 100,100 A0,0 0,1 1 100,100 Z"
                    android:fillColor="#40FFF09020"
                    android:fillAlpha="0" />
            </group>
            
            <!-- Automation taps -->
            <group android:name="automation_group">
                <path
                    android:name="tap1"
                    android:pathData="M80,65 A5,5 0,1 1 80,75 A5,5 0,1 1 80,65 Z"
                    android:fillColor="#FF80C0F0"
                    android:fillAlpha="0" />
                <path
                    android:name="tap2"
                    android:pathData="M100,85 A5,5 0,1 1 100,95 A5,5 0,1 1 100,85 Z"
                    android:fillColor="#FF80C0F0"
                    android:fillAlpha="0" />
                <path
                    android:name="tap3"
                    android:pathData="M120,65 A5,5 0,1 1 120,75 A5,5 0,1 1 120,65 Z"
                    android:fillColor="#FF80C0F0"
                    android:fillAlpha="0" />
                
                <!-- Swipe gesture -->
                <path
                    android:name="swipe"
                    android:pathData="M70,120 Q100,100 130,120"
                    android:strokeColor="#FF80C0F0"
                    android:strokeWidth="2"
                    android:strokeAlpha="0" />
                
                <!-- Type gesture -->
                <path
                    android:name="type"
                    android:pathData="M85,140 L115,140"
                    android:strokeColor="#FF80C0F0"
                    android:strokeWidth="2"
                    android:strokeAlpha="0" />
            </group>
        </vector>
    </aapt:attr>
    
    <!-- Overlay circle expanding animation -->
    <target android:name="overlay_circle">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="pathData"
                    android:valueFrom="M100,100 A0,0 0,1 1 100,100 A0,0 0,1 1 100,100 Z"
                    android:valueTo="M100,100 A50,50 0,1 1 100,100 A50,50 0,1 1 100,100 Z"
                    android:valueType="pathType"
                    android:duration="1000"
                    android:startOffset="500"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="500" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Agent eye appearing -->
    <target android:name="agent_eye">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="pathData"
                    android:valueFrom="M100,100 A0,0 0,1 1 100,100 A0,0 0,1 1 100,100 Z"
                    android:valueTo="M100,95 A5,5 0,1 1 100,105 A5,5 0,1 1 100,95 Z"
                    android:valueType="pathType"
                    android:duration="500"
                    android:startOffset="1000"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="1000" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Divine glow pulsing -->
    <target android:name="divine_glow">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="pathData"
                    android:valueFrom="M100,100 A0,0 0,1 1 100,100 A0,0 0,1 1 100,100 Z"
                    android:valueTo="M100,100 A70,70 0,1 1 100,100 A70,70 0,1 1 100,100 Z"
                    android:valueType="pathType"
                    android:duration="800"
                    android:startOffset="1200"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="0.3"
                    android:duration="800"
                    android:startOffset="1200" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Automation taps animation -->
    <target android:name="tap1">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="0.8"
                    android:duration="200"
                    android:startOffset="1500"
                    android:repeatCount="infinite"
                    android:repeatMode="restart" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="tap2">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="0.8"
                    android:duration="200"
                    android:startOffset="1800"
                    android:repeatCount="infinite"
                    android:repeatMode="restart" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="tap3">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="0.8"
                    android:duration="200"
                    android:startOffset="2100"
                    android:repeatCount="infinite"
                    android:repeatMode="restart" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Swipe gesture animation -->
    <target android:name="swipe">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2400"
                    android:repeatCount="infinite"
                    android:repeatMode="restart" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Type gesture animation -->
    <target android:name="type">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2700"
                    android:repeatCount="infinite"
                    android:repeatMode="restart" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>