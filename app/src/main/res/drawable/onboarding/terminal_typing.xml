<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    
    <aapt:attr name="android:drawable">
        <vector
            android:width="200dp"
            android:height="200dp"
            android:viewportWidth="200"
            android:viewportHeight="200">
            
            <!-- Terminal window -->
            <group
                android:name="terminal_group"
                android:pivotX="100"
                android:pivotY="100">
                
                <!-- Terminal background -->
                <path
                    android:name="terminal_bg"
                    android:pathData="M20,30 L180,30 Q190,30 190,40 L190,160 Q190,170 180,170 L20,170 Q10,170 10,160 L10,40 Q10,30 20,30 Z"
                    android:fillColor="#FF0A0A0A"
                    android:strokeColor="#FF282828"
                    android:strokeWidth="2" />
                
                <!-- Terminal header -->
                <path
                    android:name="terminal_header"
                    android:pathData="M20,30 L180,30 L180,50 L20,50 Z"
                    android:fillColor="#FF1E1E1E" />
                
                <!-- Terminal buttons -->
                <path
                    android:name="close_btn"
                    android:pathData="M30,40 A5,5 0,1 1 30,50 A5,5 0,1 1 30,40 Z"
                    android:fillColor="#FFFF4444" />
                <path
                    android:name="minimize_btn"
                    android:pathData="M45,40 A5,5 0,1 1 45,50 A5,5 0,1 1 45,40 Z"
                    android:fillColor="#FFFFAA00" />
                <path
                    android:name="maximize_btn"
                    android:pathData="M60,40 A5,5 0,1 1 60,50 A5,5 0,1 1 60,40 Z"
                    android:fillColor="#FF00FF00" />
                
                <!-- Terminal title -->
                <path
                    android:name="terminal_title"
                    android:pathData="M80,40 L120,40 L120,50 L80,50 Z"
                    android:fillColor="#FF282828" />
                
                <!-- Command prompt -->
                <path
                    android:name="prompt_symbol"
                    android:pathData="M25,70 L35,70 L35,80 L25,80 Z"
                    android:fillColor="#FFF09020" />
                
                <!-- Cursor -->
                <path
                    android:name="cursor"
                    android:pathData="M40,70 L45,70 L45,80 L40,80 Z"
                    android:fillColor="#FFFFFFFF"
                    android:fillAlpha="0" />
                
                <!-- Command text elements -->
                <group android:name="command_group">
                    <path
                        android:name="char1"
                        android:pathData="M40,70 L45,70 L45,80 L40,80 Z"
                        android:fillColor="#FFFFFFFF"
                        android:fillAlpha="0" />
                    <path
                        android:name="char2"
                        android:pathData="M47,70 L52,70 L52,80 L47,80 Z"
                        android:fillColor="#FFFFFFFF"
                        android:fillAlpha="0" />
                    <path
                        android:name="char3"
                        android:pathData="M54,70 L59,70 L59,80 L54,80 Z"
                        android:fillColor="#FFFFFFFF"
                        android:fillAlpha="0" />
                    <path
                        android:name="char4"
                        android:pathData="M61,70 L66,70 L66,80 L61,80 Z"
                        android:fillColor="#FFFFFFFF"
                        android:fillAlpha="0" />
                    <path
                        android:name="char5"
                        android:pathData="M68,70 L73,70 L73,80 L68,80 Z"
                        android:fillColor="#FFFFFFFF"
                        android:fillAlpha="0" />
                </group>
                
                <!-- CLI icons -->
                <group android:name="cli_icons">
                    <!-- Claude Code -->
                    <path
                        android:name="claude_icon"
                        android:pathData="M30,90 A10,10 0,1 1 30,110 A10,10 0,1 1 30,90 Z"
                        android:fillColor="#FFD97706"
                        android:strokeColor="#FFB45309"
                        android:strokeWidth="1" />
                    
                    <!-- Codex -->
                    <path
                        android:name="codex_icon"
                        android:pathData="M70,90 A10,10 0,1 1 70,110 A10,10 0,1 1 70,90 Z"
                        android:fillColor="#FF10A37F"
                        android:strokeColor="#FF0D8C6C"
                        android:strokeWidth="1" />
                    
                    <!-- Hermes Agent -->
                    <path
                        android:name="hermes_icon"
                        android:pathData="M110,90 A10,10 0,1 1 110,110 A10,10 0,1 1 110,90 Z"
                        android:fillColor="#FF8B5CF6"
                        android:strokeColor="#FF7C3AED"
                        android:strokeWidth="1" />
                    
                    <!-- Ubuntu -->
                    <path
                        android:name="ubuntu_icon"
                        android:pathData="M150,90 A10,10 0,1 1 150,110 A10,10 0,1 1 150,90 Z"
                        android:fillColor="#FFE95420"
                        android:strokeColor="#FFCC4A1A"
                        android:strokeWidth="1" />
                </group>
                
                <!-- Terminal output lines -->
                <group android:name="output_lines">
                    <path
                        android:name="line1"
                        android:pathData="M25,120 L175,120"
                        android:strokeColor="#FF405050"
                        android:strokeWidth="1"
                        android:strokeAlpha="0" />
                    <path
                        android:name="line2"
                        android:pathData="M25,130 L150,130"
                        android:strokeColor="#FF405050"
                        android:strokeWidth="1"
                        android:strokeAlpha="0" />
                    <path
                        android:name="line3"
                        android:pathData="M25,140 L160,140"
                        android:strokeColor="#FF405050"
                        android:strokeWidth="1"
                        android:strokeAlpha="0" />
                </group>
            </group>
        </vector>
    </aapt:attr>
    
    <!-- Cursor blinking animation -->
    <target android:name="cursor">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/linear" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Command typing animation -->
    <target android:name="char1">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="50"
                    android:startOffset="1000" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="char2">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="50"
                    android:startOffset="1200" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="char3">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="50"
                    android:startOffset="1400" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="char4">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="50"
                    android:startOffset="1600" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="char5">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="50"
                    android:startOffset="1800" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- CLI icons appearing animation -->
    <target android:name="claude_icon">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2000"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2000"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="codex_icon">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2300"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2300"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="hermes_icon">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2600"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2600"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="ubuntu_icon">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2900"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="500"
                    android:startOffset="2900"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>
    
    <!-- Output lines appearing -->
    <target android:name="line1">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="300"
                    android:startOffset="3200" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="line2">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="300"
                    android:startOffset="3500" />
            </set>
        </aapt:attr>
    </target>
    
    <target android:name="line3">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:duration="300"
                    android:startOffset="3800" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>